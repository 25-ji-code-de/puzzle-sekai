{
  "name": "puzzle-sekai",
  "version": "1.1.0",
  "description": "パズル⭐︎セカ - Project SEKAI fan group-clear / Puyo-style falling-block browser game.",
  "license": "AGPL-3.0-only",
  "scripts": {
    "start": "vite --port 7426",
    "build": "vite build",
    "preview": "vite preview",
    "fonts:subset": "node scripts/subset-fonts.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "ci": "yarn test && yarn typecheck && yarn lint && yarn format:check && yarn build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/qrcode": "^1.5.6",
    "eslint": "^10.7.0",
    "eslint-plugin-unicorn": "^72.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.6.2",
    "sass": "^1.26.10",
    "sharp": "^0.35.3",
    "subset-font": "^2.5.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "@dimforge/rapier2d-compat": "^0.19.3",
    "@types/hammerjs": "^2.0.36",
    "hammerjs": "^2.0.8",
    "pixi-sound": "^3.0.4",
    "pixi.js-legacy": "^5.3.2",
    "qrcode": "^1.5.4"
  },
  "packageManager": "yarn@4.17.0"
}
