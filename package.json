{
  "name": "puzzle-sekai",
  "version": "1.1.0",
  "description": "パズル⭐︎セカ - A Puyo-puyo-inspired puzzle game with Project SEKAI characters.",
  "license": "AGPL-3.0-only",
  "scripts": {
    "start": "vite --port 7426",
    "build": "vite build",
    "preview": "vite preview",
    "fonts:subset": "node scripts/subset-fonts.mjs",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "prettier": "^2.1.2",
    "sass": "^1.26.10",
    "sharp": "^0.35.3",
    "subset-font": "^2.5.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "@types/hammerjs": "^2.0.36",
    "hammerjs": "^2.0.8",
    "pixi-sound": "^3.0.4",
    "pixi.js": "^5.3.0",
    "pixi.js-legacy": "^5.3.2"
  },
  "packageManager": "yarn@4.17.0"
}
