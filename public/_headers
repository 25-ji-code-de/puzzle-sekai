# Cloudflare Pages headers
# https://developers.cloudflare.com/pages/configuration/headers/
# Served from build output (Vite copies public/ → dist/).
#
# CSP is enforced (Content-Security-Policy).
#
# Why the current directives (do not "tighten blind"):
#   - script-src 'unsafe-inline': index.html has two classic inline boot scripts
#     (early locale + boot-shell copy). JSON-LD is type=application/ld+json.
#   - script-src 'unsafe-eval': pixi.js-legacy builds shaders via `new Function`.
#   - script-src 'wasm-unsafe-eval': Rapier2D WASM (truePhysics).
#   - style-src 'unsafe-inline': critical boot CSS lives in <style> for LCP.
#   - connect-src: SEKAI Pass + gateway defaults (auth/config.ts). Override
#     hosts via VITE_SEKAI_PASS_ISSUER / VITE_GATEWAY_BASE require a matching
#     CSP update. Also cloudflareinsights.com for CF Web Analytics beacon POSTs
#     (Pages injects this when Analytics is enabled on the project).
#   - script-src static.cloudflareinsights.com — CF Web Analytics beacon.min.js
#     (auto-injected by Cloudflare; not in our index.html).
#   - img-src data: blob: — QR toDataURL + share-card download ObjectURL.
#   - worker-src 'self' — vite-plugin-pwa Service Worker (sw.js + workbox).
#   - No report-uri yet: add report-uri/report-to when a collector exists.
#
# CSP does not apply the same way to the SW global scope as to the page.
# Keep SW headers lean; page CSP already covers registerSW.js + module graph.

# Shared CSP value (enforce). One line — CF _headers is line-oriented.
# frame-ancestors is active under enforce; X-Frame-Options remains as a
# belt-and-suspenders clickjacking control for older clients.
#
# HTML shell — always revalidate
/
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; media-src 'self'; connect-src 'self' https://id.nightcord.de5.net https://api.nightcord.de5.net https://cloudflareinsights.com; worker-src 'self'; manifest-src 'self';

/index.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; media-src 'self'; connect-src 'self' https://id.nightcord.de5.net https://api.nightcord.de5.net https://cloudflareinsights.com; worker-src 'self'; manifest-src 'self';

# Service worker / PWA — never long-cache
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/javascript; charset=utf-8

/registerSW.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/manifest+json

# Hashed Vite assets — immutable year-long cache
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# SEO / AI text files
/robots.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/xml; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

# Social preview + PWA icons (rarely change; short-to-medium cache)
/og-image.jpg
  Cache-Control: public, max-age=86400
  Content-Type: image/jpeg

/android-chrome-512x512.png
  Cache-Control: public, max-age=86400

/android-chrome-192x192.png
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

# Source maps (open-source debugging) — cacheable but not precached by SW
/assets/*.map
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
