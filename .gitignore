.DS_STORE

# Logs
logs
*.log

**/psd
**/old
**.mkv

# Runtime data
pids
*.pid
*.seed

# Dependency directory
node_modules

# Yarn Berry — ignore local install artifacts; keep patches/plugins/releases/sdks/versions.
# .pnp.cjs / .pnp.loader.mjs are committed so resolvers match lock without regenerating first.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Coverage
coverage

# Compiled binary addons
build/Release

# JetBrains
*.iml
.idea/
out/
.idea_modules/

# Build
/dist/
.cache/

# Tauri
src-tauri/target/

# Capacitor / Android local
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/captures/
*.apk
*.aab
*.keystore
!debug.keystore

# Local env (keep .env.example)
.env
.env.local
.env.*.local
.env.development
.env.production
# .env.native is committed (public OAuth client + VITE_NATIVE=1 defaults)

# Audio
*.m4a
