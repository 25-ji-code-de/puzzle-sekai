{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Puzzle SEKAI",
  "version": "1.1.0",
  "identifier": "de.nightcord.puzzlesekai",
  "build": {
    "beforeDevCommand": "yarn start",
    "devUrl": "http://localhost:7426",
    "beforeBuildCommand": "yarn build:native",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "パズル⭐︎セカ | Puzzle × SEKAI",
        "width": 1280,
        "height": 720,
        "minWidth": 960,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["puzzlesekai"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Project SEKAI fan group-clear puzzle",
    "longDescription": "パズル⭐︎セカ | Puzzle × SEKAI — a Project SEKAI themed falling-block group-clear game. Unofficial fan work.",
    "copyright": "AGPL-3.0-only. Game assets © their respective rights holders.",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
