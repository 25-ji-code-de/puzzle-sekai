{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "newLine": "LF",
    "sourceMap": true,
    "declaration": true,
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "ESNext"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [".git", "node_modules"]
}
